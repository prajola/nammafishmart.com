# ── Catalog admin backend (optional) ──────────────────────────────────────
# Leave these UNSET to run in local preview mode (admin edits persist only in
# the editor's browser). Set them to make the admin portal persist to Supabase
# so edits are live in PRODUCTION for every visitor. See ADMIN_SETUP.md.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Passcode for the LOCAL-mode admin gate only (ignored when Supabase is set).
# Defaults to "admin" if unset. Not real security — for preview convenience.
VITE_ADMIN_PASSCODE=admin
